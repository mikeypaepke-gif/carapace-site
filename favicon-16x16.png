  <!-- ==================== FEATURES ==================== -->
  <section id="features" class="relative py-28 md:py-36">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-20 space-y-5">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.2em] text-claw-400/80">Features</p>
        <h2 class="reveal reveal-delay-1 text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
          Everything you need.<br>
          <span class="text-white/40">Nothing you don't.</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <!-- Feature 1 -->
        <div class="reveal feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-claw-500/15 to-claw-600/10 border border-claw-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-claw-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>
          </div>
          <h3 class="text-base font-semibold">Native on Every Device</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            Built with SwiftUI for iPhone and Mac. Not a web wrapper — a real app that feels right at home on every Apple device.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="reveal reveal-delay-1 feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-shell-500/15 to-shell-600/10 border border-shell-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-shell-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/></svg>
          </div>
          <h3 class="text-base font-semibold">Live Agent Monitoring</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            Watch your agents think in real-time. Monitor token usage, subagent trees, active sessions, and kill runaway processes with a tap.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="reveal reveal-delay-2 feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-green-500/15 to-green-600/10 border border-green-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <h3 class="text-base font-semibold">Zero-Trust Security</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            Encrypted end-to-end. No cloud relay, no data leaves your mesh. Pair via QR code, connect over Tailscale or direct TLS.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="reveal feature-card glass rounded-2xl p-7 space-y-4 opacity-60">
          <div class="flex items-start justify-between">
            <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-amber-500/15 to-amber-600/10 border border-amber-500/10 flex items-center justify-center transition-transform duration-300">
              <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
            </div>
