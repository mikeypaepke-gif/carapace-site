        <!-- Feature 5 -->
        <div class="reveal reveal-delay-1 feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-purple-500/15 to-purple-600/10 border border-purple-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-base font-semibold">Eyes — Live Vision</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            Point your camera at anything — your AI sees it in real time. Ask questions, get analysis, read documents, identify objects. Your agent goes eyes-on with you.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="reveal reveal-delay-2 feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-500/15 to-cyan-600/10 border border-cyan-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
          </div>
          <h3 class="text-base font-semibold">Dedicated Voice Mode</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            A full hands-free voice interface built for real use — driving, cooking, working. Talk naturally, get spoken responses.
          </p>
          <p class="text-sm text-white/25 leading-relaxed">
            Vision analysis routes through Gemini Flash first — fast, cheap, and on-device enough to handle most requests without touching your OpenClaw agent. Only escalates when it needs to. Fully editable Gemini base prompt in-app so you control exactly when and how it escalates.
          </p>
        </div>
        <!-- Feature 7 -->
        <div class="reveal feature-card glass rounded-2xl p-7 space-y-4">
          <div class="feature-icon-wrap w-12 h-12 rounded-2xl bg-gradient-to-br from-purple-500/15 to-purple-600/10 border border-purple-500/10 flex items-center justify-center transition-transform duration-300">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/></svg>
          </div>
          <h3 class="text-base font-semibold">Projects &amp; Cron Jobs</h3>
          <p class="text-sm text-white/35 leading-relaxed">
            See every active project and scheduled job in one view. Track workstreams, completion percentages, and what’s running in the background — without opening a terminal.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ==================== EYES / VISION ==================== -->
