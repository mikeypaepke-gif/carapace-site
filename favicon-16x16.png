  <!-- ==================== HERO ==================== -->
  <section class="hero-glow min-h-screen flex items-center relative">
    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-28 pb-20 md:pt-32 md:pb-28 w-full">
      <!-- Top: centered copy -->
      <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
        <div class="reveal inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full glass-elevated text-xs font-medium text-white/60 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
